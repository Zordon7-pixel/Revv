# Database
DATABASE_URL=postgresql://user:password@localhost:5432/revv

# Security
JWT_SECRET=your-jwt-secret-key-here

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Email — Resend (via zordontechnologies.com domain)
RESEND_API_KEY=re_xxxxxxxxxxxxxx
RESEND_FROM=REVV <noreply@zordontechnologies.com>

# Portal URL (optional, used in email links)
PORTAL_URL=https://app.revvshop.com/portal

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_test_xxxxxxxxxxxxxx

# Legacy Email (fallback, if Resend is not configured)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@example.com

# SMS (Twilio)
TWILIO_ACCOUNT_SID=AC_xxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Anthropic (for AI features)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxx
